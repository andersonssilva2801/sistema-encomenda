# ===========================================
# Sistema de Encomendas - Variáveis de Ambiente
# ===========================================
# Copie este arquivo para .env e preencha os valores:
#   copy .env.example .env

# Ambiente: development | production | testing
FLASK_ENV=development

# Chave secreta para sessões e CSRF (gere uma chave forte em produção!)
# Para gerar: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=minha-chave-secreta-trocar-em-producao

# URL de conexão com o banco de dados
# Desenvolvimento (SQLite local):
DATABASE_URL=sqlite:///instance/sistema_encomenda.db

# Produção (PostgreSQL - Supabase):
# DATABASE_URL=postgresql://usuario:senha@host:porta/nome_banco

# Porta do servidor (padrão: 5000)
PORT=5000
